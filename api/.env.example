# ============================================================
# ITHub API — variables de entorno
# Copiar a .env y completar. NUNCA commitear .env.
# ============================================================

# ---------- App ----------
APP_NAME="ITHub API"
APP_ENV=production                 # local | staging | production
APP_DEBUG=false                    # NUNCA true en producción
APP_URL=https://apithub.intellihelp.tech
FRONTEND_URL=https://ithub.intellihelp.tech
TIMEZONE=America/Argentina/Buenos_Aires

# ---------- Base de datos (runtime, privilegios mínimos) ----------
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ithub
DB_USER=ithub_app                  # usuario con SELECT/INSERT/UPDATE/DELETE solamente
DB_PASS=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ---------- Base de datos (migraciones - solo usar vía CLI/SSH) ----------
DB_MIGRATE_USER=ithub_migrate
DB_MIGRATE_PASS=

# ---------- JWT ----------
# Generar con: openssl rand -base64 32
JWT_SECRET=
JWT_ISSUER=https://apithub.intellihelp.tech
JWT_AUDIENCE=https://ithub.intellihelp.tech
JWT_ACCESS_TTL=900                 # 15 min
JWT_REFRESH_TTL=604800             # 7 días

# ---------- Cookies ----------
# IMPORTANTE: usar el dominio PADRE compartido entre el front y el API,
# con punto adelante, para que el front (ithub.intellihelp.tech) pueda leer
# la cookie CSRF que setea el API (apithub.intellihelp.tech). Si se usa el
# host-only del API, el double-submit CSRF se rompe tras un reload.
COOKIE_DOMAIN=.intellihelp.tech
COOKIE_SECURE=true
COOKIE_SAMESITE=Strict

# ---------- Cron ----------
# Generar con: openssl rand -hex 32
CRON_TOKEN=
CRON_ALLOWED_IPS=127.0.0.1,::1

# ---------- Google Drive ----------
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=storage/credentials/service-account.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_IMPERSONATE_USER=

# ---------- SMTP (también configurable desde admin UI) ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=facturacion@intellihelp.tech
SMTP_FROM_NAME="ITHub Facturación"
SMTP_ENCRYPTION=tls                # tls | ssl

# ---------- Notificaciones ----------
NOTIF_DIAS_PREVIOS=3,1,0           # avisar X días antes del vencimiento
NOTIF_DIAS_VENCIDA=1,7,15,30       # avisar X días después de vencer
NOTIF_CC_EMAILS=                   # separados por coma

# ---------- Logging ----------
LOG_LEVEL=info                     # debug | info | warning | error
LOG_RETENTION_DAYS=90

# ---------- Backups ----------
BACKUP_GPG_PASSPHRASE=             # generar y guardar separadamente
BACKUP_RETENTION_DAYS=7

# ---------- Seguridad ----------
# IPs en allowlist para login del admin (opcional, vacío = sin restricción)
ADMIN_IP_ALLOWLIST=
# Headers de seguridad
HSTS_MAX_AGE=31536000
ENABLE_HSTS=true
