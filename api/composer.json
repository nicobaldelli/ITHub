{
    "name": "ithub/api",
    "description": "ITHub - API REST para gestion de facturas de venta",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "ext-pdo": "*",
        "ext-mbstring": "*",
        "ext-json": "*",
        "ext-openssl": "*",
        "ext-zip": "*",
        "ext-intl": "*",
        "ext-fileinfo": "*",
        "slim/slim": "^4.13",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0",
        "illuminate/database": "^10.40",
        "illuminate/events": "^10.40",
        "vlucas/phpdotenv": "^5.6",
        "firebase/php-jwt": "^6.10",
        "respect/validation": "^2.3",
        "monolog/monolog": "^3.5",
        "ramsey/uuid": "^4.7",
        "phpmailer/phpmailer": "^6.9",
        "google/apiclient": "^2.15",
        "phpoffice/phpspreadsheet": "^2.0",
        "dompdf/dompdf": "^2.0",
        "ezyang/htmlpurifier": "^4.17",
        "robmorgan/phinx": "^0.16.0",
        "symfony/cache": "^6.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.8",
        "phpstan/phpstan": "^1.10",
        "mockery/mockery": "^1.6",
        "fakerphp/faker": "^1.23"
    },
    "autoload": {
        "psr-4": {
            "ITHub\\Api\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ITHub\\Api\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs --standard=PSR12 src/",
        "lint:fix": "phpcbf --standard=PSR12 src/",
        "analyse": "phpstan analyse src/ --level=6",
        "migrate": "phinx migrate -c db/phinx.php",
        "migrate:rollback": "phinx rollback -c db/phinx.php",
        "seed": "phinx seed:run -c db/phinx.php",
        "audit": "composer audit"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
