# Configuración para pnpm
# https://pnpm.io/npmrc

# Resolver peer deps automáticamente
auto-install-peers=true

# Lockfile siempre presente y respetado
lockfile=true
prefer-frozen-lockfile=true

# pnpm v9 pide confirmación antes de correr scripts de install (defensa contra
# paquetes maliciosos con post-install hooks). Para CI/CD se usa el campo
# `pnpm.onlyBuiltDependencies` en package.json como allow-list explícita.
